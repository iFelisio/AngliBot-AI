rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - email: string (optional)
    //   - isAdmin: boolean (required)
    //   - streak: number
    //   - lastLogin: string
    //   - points: number
    //   - badges: list
    //   - proficiency: string
    //   - goal: string
    //   - password: string
    //
    // Collection: dialogues
    // Document ID: dialogueId
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - audioData: string
    //   - videoData: string
    //   - addedBy: string
    //   - level: string
    //   - createdAt: string
    //
    // Collection: animations
    // Document ID: animationId
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - videoData: string (required)
    //   - addedBy: string
    //   - createdAt: string
    //
    // Collection: suggestions
    // Document ID: suggestionId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - text: string (required)
    //   - date: string (required)
    //   - adminResponse: string
    //
    // Collection: logs
    // Document ID: logId
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - timestamp: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "pajtim1.2.bollobani@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.id is string && data.name is string && data.isAdmin is bool;
    }

    function isValidDialogue(data) {
      return data.id is string && data.title is string && data.content is string && data.level is string;
    }

    function isValidAnimation(data) {
      return data.id is string && data.title is string && data.videoData is string;
    }

    function isValidSuggestion(data) {
      return data.id is string && data.userId is string && data.userName is string && data.text is string;
    }

    function isValidLog(data) {
      return data.id is string && data.userId is string && data.userName is string && data.timestamp is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.isAdmin == false) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dialogues/{dialogueId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /animations/{animationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSuggestion(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
