rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "pajtim1.2.bollobani@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile, or admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile. They cannot set isAdmin to true unless they are already an admin.
      allow create: if isOwner(userId) && 
                    request.resource.data.keys().hasAll(['name', 'email', 'isAdmin', 'points', 'streak', 'lastLogin']) &&
                    request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
                    request.resource.data.email is string &&
                    request.resource.data.points is number && request.resource.data.points >= 0 &&
                    request.resource.data.streak is number && request.resource.data.streak >= 0 &&
                    request.resource.data.lastLogin is string &&
                    (request.resource.data.isAdmin == false || isAdmin());

      // Users can update their own profile, but cannot change isAdmin. Admins can update anything.
      allow update: if (isOwner(userId) && 
                        request.resource.data.isAdmin == resource.data.isAdmin &&
                        request.resource.data.email == resource.data.email) || 
                       isAdmin();
    }

    match /dialogues/{dialogueId} {
      // Any authenticated user can read dialogues
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete dialogues
      allow create, update, delete: if isAdmin();
    }

    match /animations/{animationId} {
      // Any authenticated user can read animations
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete animations
      allow create, update, delete: if isAdmin();
    }
  }
}
