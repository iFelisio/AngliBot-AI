{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the AngliBot AI platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "streak": { "type": "integer" },
        "lastLogin": { "type": "string" },
        "points": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "proficiency": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "goal": { "type": "string", "enum": ["Conversational", "Business", "Exam Prep", "Travel"] },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "isAdmin"]
    },
    "Dialogue": {
      "title": "Dialogue",
      "description": "An educational dialogue for learning English.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "audioData": { "type": "string" },
        "videoData": { "type": "string" },
        "addedBy": { "type": "string" },
        "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "content", "level"]
    },
    "Animation": {
      "title": "Animation",
      "description": "An educational animation video link.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "videoData": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "videoData"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "A suggestion from a user to the admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string" },
        "adminResponse": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "text", "date"]
    },
    "Log": {
      "title": "Log",
      "description": "A login event log.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/dialogues/{dialogueId}": {
      "schema": "Dialogue",
      "description": "Educational dialogues."
    },
    "/animations/{animationId}": {
      "schema": "Animation",
      "description": "Educational animations."
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "User suggestions."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "System login logs."
    }
  }
}
