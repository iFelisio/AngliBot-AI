{
  "entities": {
    "Dialogue": {
      "title": "Dialogue",
      "description": "A dialogue for students to practice.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "audioData": { "type": "string" },
        "videoData": { "type": "string" },
        "addedBy": { "type": "string" },
        "level": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "addedBy", "level", "createdAt"]
    },
    "AnimationMedia": {
      "title": "AnimationMedia",
      "description": "An animation video for the children's corner.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoData": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoData", "addedBy", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "points": { "type": "number" },
        "streak": { "type": "number" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "proficiency": { "type": "string" },
        "goal": { "type": "string" }
      },
      "required": ["name", "email", "isAdmin", "points", "streak", "lastLogin"]
    }
  },
  "firestore": {
    "dialogues/{dialogueId}": {
      "schema": { "$ref": "#/entities/Dialogue" },
      "description": "Collection of dialogues."
    },
    "animations/{animationId}": {
      "schema": { "$ref": "#/entities/AnimationMedia" },
      "description": "Collection of animations."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users."
    }
  }
}
