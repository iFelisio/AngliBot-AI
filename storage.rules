rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Lejo leximin për të gjithë (për të parë videot/audion)
      allow read: if true;
      
      // Lejo shkrimin vetëm për përdoruesit e autentikuar
      // Në një aplikacion real, do të kufizonim këtë vetëm për adminët
      allow write: if request.auth != null;
    }
  }
}
